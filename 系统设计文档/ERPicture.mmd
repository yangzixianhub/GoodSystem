erDiagram
    USER ||--o{ ORDER : places
    PRODUCT ||--|| STOCK : has
    PRODUCT ||--o{ ORDER_ITEM : contains
    ORDER ||--|{ ORDER_ITEM : includes

    USER {
        bigint id PK
        string username
        string password
        string phone
    }
    PRODUCT {
        bigint id PK
        string name
        decimal price
        string description
    }
    STOCK {
        bigint product_id FK
        int actual_stock "实际库存"
        int lock_stock "锁定库存"
    }
    ORDER {
        bigint id PK
        bigint user_id FK
        decimal total_amount
        int status "0:待支付, 1:已支付, 2:已取消"
        datetime create_time
    }